<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <ImageView
        android:layout_width="380dp"
        android:layout_height="380dp"
        android:src="@mipmap/ic_launcher"
        android:layout_centerInParent="true"
        android:alpha="0.15"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp"
                android:background="#1A1A1A"
                android:padding="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APP 1"
                    android:textColor="#76FF03"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <Spinner
                    android:id="@+id/spinner_app1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp"
                android:background="#1A1A1A"
                android:padding="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APP 2"
                    android:textColor="#76FF03"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <Spinner
                    android:id="@+id/spinner_app2"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp"
                android:background="#1A1A1A"
                android:padding="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DELAY (secondi)"
                    android:textColor="#76FF03"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="4dp"
                    android:background="#262626">
                    <Button
                        android:id="@+id/btn_minus"
                        android:layout_width="45dp"
                        android:layout_height="match_parent"
                        android:text="-"
                        android:textSize="18sp"
                        android:backgroundTint="#333333"
                        android:textColor="#76FF03"
                        android:padding="0dp" />
                    <TextView
                        android:id="@+id/tv_delay_value"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:text="20"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#76FF03"
                        android:gravity="center" />
                    <Button
                        android:id="@+id/btn_plus"
                        android:layout_width="45dp"
                        android:layout_height="match_parent"
                        android:text="+"
                        android:textSize="18sp"
                        android:backgroundTint="#333333"
                        android:textColor="#76FF03"
                        android:padding="0dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp"
                android:background="#1A1A1A"
                android:padding="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LAUNCHER"
                    android:textColor="#76FF03"
                    android:textSize="11sp"
                    android:textStyle="bold" />
                <Spinner
                    android:id="@+id/spinner_launcher"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btn_avvio"
            android:layout_width="240dp"
            android:layout_height="45dp"
            android:layout_gravity="center_horizontal"
            android:text="▶  AVVIO"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:backgroundTint="#76FF03"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#0D1A02"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 RIEPILOGO CONFIGURAZIONE"
                android:textColor="#76FF03"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SEQUENZA"
                        android:textColor="#76FF03"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tv_col_sequenza"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. Avvia App 1\n2. Avvia App 2\n3. Attendi Delay\n4. Avvia Launcher"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:lineSpacingMultiplier="1.2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.4"
                    android:orientation="vertical"
                    android:paddingLeft="2dp"
                    android:paddingRight="2dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="APPLICAZIONI"
                        android:textColor="#76FF03"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tv_col_applicazioni"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="App 1:\n-\nApp 2:\n-\nLauncher:\n-"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:lineSpacingMultiplier="1.1" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.8"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DELAY"
                        android:textColor="#76FF03"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tv_col_delay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="20 secondi\n\nCountdown attivo"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.8"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STATO"
                        android:textColor="#76FF03"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tv_col_stato"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Pronto"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
