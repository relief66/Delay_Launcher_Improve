<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.3"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_launcher" />

    <RelativeLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:background="#111111"
        android:paddingHorizontal="16dp"
        app:layout_topToTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="DELAY LAUNCHER"
            android:textColor="#76FF03"
            android:textStyle="bold"
            android:textSize="14sp" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/box_app1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="6dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/box_app2"
        app:layout_constraintTop_toBottomOf="@id/header_bar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APP 1"
            android:textColor="#76FF03"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/spinner_app1"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@android:drawable/btn_dropdown"
            android:backgroundTint="#222222" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/box_app2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="6dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toEndOf="@+id/box_app1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_bar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APP 2"
            android:textColor="#76FF03"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/spinner_app2"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@android:drawable/btn_dropdown"
            android:backgroundTint="#222222" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/box_delay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="6dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/box_launcher"
        app:layout_constraintTop_toBottomOf="@id/box_app1">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DELAY (secondi)"
            android:textColor="#76FF03"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="#222222"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_minus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:text="-"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/tv_delay_value"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="20"
                android:textColor="#76FF03"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_plus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackground"
                android:text="+"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/box_launcher"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="6dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toEndOf="@+id/box_delay"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/box_app2">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LAUNCHER"
            android:textColor="#76FF03"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/spinner_launcher"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@android:drawable/btn_dropdown"
            android:backgroundTint="#222222" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_avvio"
        android:layout_width="180dp"
        android:layout_height="38dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#76FF03"
        android:text="▶ AVVIO"
        android:textColor="#000000"
        android:textStyle="bold"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/box_delay" />

    <LinearLayout
        android:id="@+id/box_riepilogo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="#111111"
        android:orientation="vertical"
        android:padding="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_avvio">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 RIEPILOGO CONFIGURAZIONE"
            android:textColor="#76FF03"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SEQUENZA" android:textColor="#666666" android:textSize="9sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tv_riepilogo_sequenza" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1. Avvia App 1\n2. Avvia App 2\n3. Attendi Delay\n4. Avvia Launcher" android:textColor="#FFFFFF" android:textSize="9sp" android:layout_marginTop="1dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="APPLICAZIONI" android:textColor="#666666" android:textSize="9sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tv_riepilogo_applicazioni" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="App 1: Nessuna\nApp 2: Nessuna\nLauncher: Quickstep" android:textColor="#FFFFFF" android:textSize="9sp" android:layout_marginTop="1dp" android:ellipsize="end" android:maxLines="3"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DELAY" android:textColor="#666666" android:textSize="9sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tv_riepilogo_delay" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="20 secondi\nCountdown attivo" android:textColor="#FFFFFF" android:textSize="9sp" android:layout_marginTop="1dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STATO" android:textColor="#666666" android:textSize="9sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tv_riepilogo_stato" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓ Pronto\nConfigurazione valida" android:textColor="#76FF03" android:textSize="9sp" android:layout_marginTop="1dp"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
